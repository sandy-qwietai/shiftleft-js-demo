              "helpUri": "https://cwe.mitre.org/data/definitions/918.html",
              "id": "oss_vuln/75c03d1fc4b719ecf3c683e194c1bbf6",
              "name": "Pkg:npm/Axios@0.19.0",
              "properties": {
                "precision": "very-high",
