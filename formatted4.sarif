              "id": "Secret%20Keyword/23f63e5a460d207a69841296065c75dc03884478ed1541f153d1dec25d642d27",
              "name": "Secret Keyword",
              "properties": {
                "precision": "very-high",
                "security-severity": "5.5",
                "tags": [
                  "Generic Secret",
                  "CVSS 5.5",
